# Local Docker defaults. Copy to .env.local when you need private overrides.

# PostgreSQL
POSTGRES_DB=resonance
POSTGRES_USER=resonance
POSTGRES_PASSWORD=resonance-local-password

# Application
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
JWT_SECRET=resonance-local-jwt-secret-change-before-sharing
JWT_EXPIRE_MINUTES=4320
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=adminadmin
RUN_MIGRATIONS_ON_STARTUP=true

# Matrix and Telegram are disabled by default for local Docker.
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_USER_ID=@bot:example.com
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_ID=
MATRIX_PASSWORD=
MATRIX_DM_ENABLED=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=ResonanceBot
TELEGRAM_PROXY_URL=

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=resonance
S3_SECRET_KEY=resonance-local-minio-password
S3_BUCKET=attachments
S3_PUBLIC_URL=http://localhost:8080/files
MAX_UPLOAD_SIZE_MB=10

# Optional external integrations.
KANBAN_API_BASE_URL=https://kanban.devds.ru/api
KANBAN_API_TOKEN=
KANBAN_TIMEOUT_SECONDS=20
KANBAN_BUNDLE_TASK_PAGE_SIZE=250
KANBAN_BUNDLE_CACHE_TTL_SECONDS=45
