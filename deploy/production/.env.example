# Image source. Use GHCR or GitLab Container Registry owned by the project owner.
REGISTRY=ghcr.io/project-owner
RESONANCE_VERSION=v1.2.3-a1b2c3d4

# Public endpoints.
DOMAIN=resonance.example.internal
MINIO_CONSOLE_DOMAIN=resonance-minio.example.internal
ACME_EMAIL=ops@example.internal
FRONTEND_URL=https://resonance.example.internal
CORS_ORIGINS=https://resonance.example.internal

# PostgreSQL.
POSTGRES_DB=resonance
POSTGRES_USER=resonance
POSTGRES_PASSWORD=change-this-long-random-password

# Application security.
JWT_SECRET=change-this-at-least-32-random-characters
JWT_EXPIRE_MINUTES=4320
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-before-first-run
BACKEND_WORKERS=2
RUN_MIGRATIONS_ON_STARTUP=false

# Matrix. Room IDs are configured inside the admin UI.
MATRIX_HOMESERVER=https://matrix.example.internal
MATRIX_USER_ID=@resonance-bot:example.internal
MATRIX_ACCESS_TOKEN=change-this
MATRIX_DEVICE_ID=
MATRIX_SYNC_TIMEOUT_MS=30000
MATRIX_DM_ENABLED=false

# Telegram is intentionally disabled for this deployment profile.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=ResonanceBot
TELEGRAM_PROXY_URL=

# S3-compatible storage. Default compose uses included MinIO.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=resonance-minio
S3_SECRET_KEY=change-this-long-random-password
S3_BUCKET=attachments
S3_PUBLIC_URL=https://resonance.example.internal/files
MAX_UPLOAD_SIZE_MB=10

# Optional external integrations.
KANBAN_API_BASE_URL=https://kanban.example.internal/api
KANBAN_API_TOKEN=
KANBAN_TIMEOUT_SECONDS=20
KANBAN_BUNDLE_TASK_PAGE_SIZE=250
KANBAN_BUNDLE_CACHE_TTL_SECONDS=45
